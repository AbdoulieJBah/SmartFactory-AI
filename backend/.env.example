# Copy this file to backend/.env and fill in real values.
# `docker compose up` reads DATABASE_URL/SECRET_KEY from docker-compose.yml
# for local dev; this file is for running the backend outside Docker too.

DATABASE_URL=postgresql://smartfactory_user:smartfactory_password@localhost:5432/smartfactory

SECRET_KEY=change-this-to-a-long-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed frontend origins for CORS.
# Any https://*.vercel.app origin is always allowed in addition to this list.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Get a key from https://aistudio.google.com/apikey - required for the AI copilot.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
